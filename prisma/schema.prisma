generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Organization {
  id        String   @id @default(uuid())
  name      String
  apiKey    String   @unique
  createdAt DateTime @default(now())
}

model ChatbotData {
  id             String   @id @default(uuid())
  organizationId String
  faqs           Json?
  documents      Json?
}

model Embedding {
  id             String   @id @default(uuid())
  organizationId String
  content        String
  vector         Json
}